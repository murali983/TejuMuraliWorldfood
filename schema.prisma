generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  AUTHOR
  MEMBER
  READER
}

enum RecipeStatus {
  DRAFT
  REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  BLOCKED
}

enum MediaKind {
  IMAGE
  VIDEO
  AUDIO
  THUMBNAIL
}

enum SeoStatus {
  PASS
  WARNING
  FAIL
}

model User {
  id            String             @id @default(cuid())
  name          String?
  email         String             @unique
  passwordHash  String?
  role          Role               @default(READER)
  locale        String             @default("en")
  membership    String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  reviews       Review[]
  favorites     Favorite[]
  mealPlans     MealPlan[]
  shoppingItems ShoppingListItem[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String?
  accessToken       String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  sessionState      String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuthorProfile {
  id          String   @id @default(cuid())
  userId      String?  @unique
  slug        String   @unique
  displayName String
  title       String
  bio         String   @db.Text
  photoUrl    String?
  expertise   String[]
  recipes     Recipe[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String   @db.Text
  recipes     Recipe[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Cuisine {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  region      String
  description String   @db.Text
  recipes     Recipe[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Recipe {
  id               String               @id @default(cuid())
  slug             String               @unique
  title            String
  excerpt          String               @db.Text
  description      String               @db.Text
  seoTitle         String
  seoDescription   String               @db.Text
  canonicalUrl     String?
  status           RecipeStatus         @default(DRAFT)
  country          String
  dietTags         String[]
  difficulty       String
  prepMinutes      Int
  cookMinutes      Int
  totalMinutes     Int
  servings         Int
  calories         Int
  protein          String
  carbs            String
  fat              String
  fiber            String
  sugar            String
  sodium           String
  history          String               @db.Text
  cookingTips      String[]
  storageTips      String[]
  healthBenefits   String[]
  internalLinks    Json
  imageAlt         String
  heroImageUrl     String?
  promptImage      String?              @db.Text
  promptVideo      String?              @db.Text
  qualityScore     Int                  @default(0)
  autoPublishReady Boolean              @default(false)
  publishedAt      DateTime?
  updatedAt        DateTime             @updatedAt
  createdAt        DateTime             @default(now())
  authorId         String?
  categoryId       String
  cuisineId        String
  author           AuthorProfile?       @relation(fields: [authorId], references: [id])
  category         Category             @relation(fields: [categoryId], references: [id])
  cuisine          Cuisine              @relation(fields: [cuisineId], references: [id])
  ingredients      RecipeIngredient[]
  instructions     RecipeInstruction[]
  faqs             RecipeFaq[]
  translations     RecipeTranslation[]
  mediaAssets      MediaAsset[]
  reviews          Review[]
  favorites        Favorite[]
  seoAudits        SeoAudit[]
  socialPosts      SocialPost[]

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([cuisineId])
}

model RecipeIngredient {
  id       String @id @default(cuid())
  recipeId String
  amount   String
  item     String
  notes    String?
  sort     Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, sort])
}

model RecipeInstruction {
  id       String @id @default(cuid())
  recipeId String
  title    String
  detail   String @db.Text
  sort     Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, sort])
}

model RecipeFaq {
  id       String @id @default(cuid())
  recipeId String
  question String
  answer   String @db.Text
  sort     Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, sort])
}

model RecipeTranslation {
  id             String     @id @default(cuid())
  recipeId       String
  locale         String
  title          String
  excerpt        String     @db.Text
  description    String     @db.Text
  seoTitle       String
  seoDescription String     @db.Text
  contentJson    Json
  status         JobStatus  @default(QUEUED)
  translatedAt   DateTime?
  recipe         Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, locale])
}

model MediaAsset {
  id            String    @id @default(cuid())
  recipeId      String?
  kind          MediaKind
  title         String
  altText       String?
  prompt        String?   @db.Text
  sourceUrl     String?
  cloudinaryId  String?
  format        String?
  width         Int?
  height        Int?
  moderationTag String?
  createdAt     DateTime  @default(now())
  recipe        Recipe?   @relation(fields: [recipeId], references: [id], onDelete: SetNull)
}

model Review {
  id        String   @id @default(cuid())
  recipeId  String
  userId    String?
  name      String
  rating    Int
  quote     String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([recipeId, approved])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
}

model MealPlan {
  id        String   @id @default(cuid())
  userId    String
  title     String
  days      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShoppingListItem {
  id        String   @id @default(cuid())
  userId    String
  name      String
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  locale      String   @default("en")
  source      String?
  subscribed  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())
}

model PromptTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  kind        MediaKind
  title       String
  body        String   @db.Text
  locale      String   @default("en")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AutomationJob {
  id            String    @id @default(cuid())
  key           String    @unique
  title         String
  description   String    @db.Text
  schedule      String
  status        JobStatus @default(QUEUED)
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  successCount  Int       @default(0)
  failureCount  Int       @default(0)
  payload       Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SeoAudit {
  id          String    @id @default(cuid())
  recipeId    String
  status      SeoStatus
  score       Int
  issues      String[]
  suggestions String[]
  createdAt   DateTime  @default(now())
  recipe      Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, createdAt])
}

model SocialPost {
  id          String    @id @default(cuid())
  recipeId     String
  platform     String
  locale       String
  caption      String    @db.Text
  mediaUrl     String?
  status       JobStatus @default(QUEUED)
  scheduledFor DateTime?
  publishedAt  DateTime?
  recipe       Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([platform, status])
}
